# ─────────────────────────────────────────────────────────────
# start.ai — backend configuration
# Copy this file to ".env" and adjust. Real environment variables
# always override values set here.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# OpenAI ChatGPT API.
# Leave OPENAI_API_KEY BLANK to run in MOCK mode — the app returns realistic,
# canned plans end-to-end so you can demo everything without a key or any cost.
# Set a real key (sk-...) to switch to live ChatGPT generation.
OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_SMART=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# HTTP server
PORT=8080
CORS_ALLOW_ORIGIN=*

# AI gateway — protects the single shared API account from unpredictable load.
AI_DAILY_CALLS_PER_USER=40
AI_MAX_CONCURRENCY=4
AI_MONTHLY_USD_CAP=50

# Storage — JSON snapshot lives here (created automatically).
DATA_DIR=./data

# Serve the static frontend at "/" for a one-command local run.
# Set empty to run the API only (frontend served separately).
FRONTEND_DIR=../frontend

# Missed-day rollover job. 1440 = nightly. Lower it to test rollover quickly.
ROLLOVER_INTERVAL_MINUTES=1440
